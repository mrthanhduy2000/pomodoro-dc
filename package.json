{
  "name": "pomodoro-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "PORT=31101 VITE_BIND_HOST=0.0.0.0 vite",
    "dev:open": "PORT=31101 VITE_BIND_HOST=0.0.0.0 VITE_OPEN=true vite",
    "open:chrome": "open -na \"Google Chrome\" --args --app=http://localhost:31105/",
    "open:chrome:dev": "open -na \"Google Chrome\" --args --app=http://localhost:31101/",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "PORT=31102 VITE_BIND_HOST=0.0.0.0 vite preview",
    "serve:prod": "node scripts/serve-dist.mjs",
    "install:agent": "bash scripts/install-launch-agent.sh",
    "uninstall:agent": "bash scripts/uninstall-launch-agent.sh",
    "electron": "NODE_ENV=development electron .",
    "electron-dev": "concurrently -k -n Vite,Electron -c cyan,yellow \"PORT=31101 VITE_BIND_HOST=0.0.0.0 vite\" \"wait-on http://localhost:31101 && VITE_DEV_SERVER_URL=http://localhost:31101 NODE_ENV=development electron .\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.5"
  }
}
